{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.3leaps.dev/gonimbus/v1.0.0/atlas-header.schema.json",
  "title": "Gonimbus Atlas Header",
  "description": "Header contract for gonimbus.atlas.v1 local atlas artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "atlas_id",
    "created_at",
    "source_index_set_id",
    "source_run_id",
    "base_uri",
    "scope_digest",
    "recipe_digest",
    "hash_profile",
    "coverage",
    "shard_by",
    "dimensions",
    "system_fields",
    "counts"
  ],
  "properties": {
    "schema_version": {
      "const": "gonimbus.atlas.v1"
    },
    "atlas_id": {
      "type": "string",
      "pattern": "^atlas_[0-9a-f]{64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_index_set_id": {
      "type": "string",
      "pattern": "^idx_[0-9a-f]+$"
    },
    "source_run_id": {
      "type": "string",
      "pattern": "^run_[A-Za-z0-9]+$"
    },
    "base_uri": {
      "type": "string",
      "minLength": 1
    },
    "scope_digest": {
      "type": "string"
    },
    "recipe_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "hash_profile": {
      "const": "sha256"
    },
    "coverage": {
      "enum": [
        "full",
        "scoped"
      ]
    },
    "shard_by": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/dimension"
      }
    },
    "system_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/system_field"
      }
    },
    "counts": {
      "$ref": "#/$defs/counts"
    }
  },
  "$defs": {
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "classification"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "kind": {
          "enum": [
            "temporal-day",
            "temporal-instant",
            "categorical"
          ]
        },
        "classification": {
          "$ref": "#/$defs/classification"
        }
      }
    },
    "system_field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "classification"
      ],
      "properties": {
        "name": {
          "enum": [
            "content_hash",
            "storage_key",
            "source_uri",
            "source_index_set_id",
            "source_run_id",
            "first_seen_at",
            "run_timestamp",
            "coverage",
            "scope_digest",
            "recipe_digest",
            "hash_profile"
          ]
        },
        "classification": {
          "$ref": "#/$defs/classification"
        }
      }
    },
    "classification": {
      "enum": [
        "unknown",
        "0-public",
        "1-confidential",
        "2-blinded",
        "3-proprietary",
        "4-personal",
        "5-privileged",
        "6-eyes-only"
      ]
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objects_scanned",
        "rows_written",
        "diagnostics",
        "read_failures",
        "extraction_failures",
        "validation_failures"
      ],
      "properties": {
        "objects_scanned": {
          "type": "integer",
          "minimum": 0
        },
        "rows_written": {
          "type": "integer",
          "minimum": 0
        },
        "diagnostics": {
          "type": "integer",
          "minimum": 0
        },
        "read_failures": {
          "type": "integer",
          "minimum": 0
        },
        "extraction_failures": {
          "type": "integer",
          "minimum": 0
        },
        "validation_failures": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_write_failures": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
