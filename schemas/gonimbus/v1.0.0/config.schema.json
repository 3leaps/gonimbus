{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gonimbus/v1.0.0/config",
  "title": "Gonimbus Workhorse Configuration Schema",
  "description": "Configuration schema for forge-workhorse-gonimbus template following Fulmen Forge Workhorse Standard",
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "read_timeout": {
          "type": "string"
        },
        "write_timeout": {
          "type": "string"
        },
        "idle_timeout": {
          "type": "string"
        },
        "shutdown_timeout": {
          "type": "string"
        }
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "trace",
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        "profile": {
          "type": "string",
          "enum": [
            "SIMPLE",
            "STRUCTURED",
            "ENTERPRISE"
          ]
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "health": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "debug": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "pprof_enabled": {
          "type": "boolean"
        }
      }
    },
    "workers": {
      "type": "integer",
      "minimum": 1
    },
    "on_collision": {
      "type": "string",
      "description": "Default collision behavior for transfer reflow. log is a deprecated alias for skip-if-duplicate.",
      "enum": [
        "skip-if-duplicate",
        "log",
        "fail",
        "overwrite",
        "quarantine"
      ],
      "default": "skip-if-duplicate"
    },
    "collision_quarantine_prefix": {
      "type": "string",
      "description": "Relative destination prefix used when transfer reflow on_collision is quarantine."
    },
    "provenance": {
      "type": "object",
      "description": "Default provenance behavior for transfer reflow.",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "sidecar"
          ],
          "default": "none"
        },
        "suffix": {
          "type": "string",
          "default": ".gnb.json",
          "pattern": "^\\.[^/*?\\[]+$"
        },
        "on_write_error": {
          "type": "string",
          "enum": [
            "warn",
            "fail"
          ],
          "default": "warn"
        },
        "allow_unsafe_suffix": {
          "type": "boolean",
          "default": false
        }
      }
    }
  },
  "additionalProperties": false
}
