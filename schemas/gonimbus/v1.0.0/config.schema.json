{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gonimbus/v1.0.0/config",
  "title": "Gonimbus Workhorse Configuration Schema",
  "description": "Configuration schema for forge-workhorse-gonimbus template following Fulmen Forge Workhorse Standard",
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "read_timeout": {
          "type": "string"
        },
        "write_timeout": {
          "type": "string"
        },
        "idle_timeout": {
          "type": "string"
        },
        "shutdown_timeout": {
          "type": "string"
        }
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "trace",
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        "profile": {
          "type": "string",
          "enum": [
            "SIMPLE",
            "STRUCTURED",
            "ENTERPRISE"
          ]
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "health": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "debug": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "pprof_enabled": {
          "type": "boolean"
        }
      }
    },
    "workers": {
      "type": "integer",
      "minimum": 1
    },
    "data_root": {
      "type": "string",
      "description": "Optional app-wide operational data root for indexes, job records, and operation checkpoints. Empty uses the platform app-data default."
    },
    "data_dir": {
      "type": "string",
      "description": "Compatibility alias for data_root."
    },
    "memory_budget": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+)?\\s*([KMGT]i?B?|[kmgt]i?b?|B|b)?$",
      "description": "Transfer memory budget sizing the reflow concurrency ceiling, as a size string with SI or IEC units (e.g. 512MiB, 8GiB) or raw bytes. Minimum 64MiB, maximum 4TiB; values above the detected memory limit are clamped to it. Empty derives 25% of the detected limit."
    },
    "on_collision": {
      "type": "string",
      "description": "Default collision behavior for transfer reflow. log is a deprecated alias for skip-if-duplicate.",
      "enum": [
        "skip-if-duplicate",
        "log",
        "fail",
        "overwrite",
        "quarantine",
        "overwrite-if-source-newer"
      ],
      "default": "skip-if-duplicate"
    },
    "collision_quarantine_prefix": {
      "type": "string",
      "description": "Relative destination prefix used when transfer reflow on_collision is quarantine."
    },
    "provenance": {
      "type": "object",
      "description": "Default provenance behavior for transfer reflow.",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "sidecar"
          ],
          "default": "none"
        },
        "suffix": {
          "type": "string",
          "default": ".gnb.json",
          "pattern": "^\\.[^/*?\\[]+$"
        },
        "sidecar_root": {
          "type": "string",
          "description": "Optional mirrored-root URI for provenance sidecars. Must use the destination provider scheme, end in '/', and for s3:// use the destination bucket."
        },
        "on_write_error": {
          "type": "string",
          "enum": [
            "warn",
            "fail"
          ],
          "default": "warn"
        },
        "allow_unsafe_suffix": {
          "type": "boolean",
          "default": false
        }
      }
    }
  },
  "additionalProperties": false
}
