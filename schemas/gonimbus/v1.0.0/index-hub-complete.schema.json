{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gonimbus/v1.0.0/index-hub-complete",
  "title": "Gonimbus Index Hub Complete Marker",
  "description": "Commit marker for an exported index run. Written last after all artifacts (index.db, identity.json) are uploaded. Presence of this file indicates the run is fully published and safe to hydrate.",
  "type": "object",
  "required": [
    "version",
    "index_set_id",
    "run_id",
    "completed_at",
    "artifacts"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema reference for editor support"
    },
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Complete marker schema version"
    },
    "index_set_id": {
      "type": "string",
      "pattern": "^idx_[0-9a-f]{64}$",
      "description": "Full index set identity hash"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_([0-9]{1,32}|[0-9A-HJKMNP-TV-Z]{26})$",
      "description": "Run identifier (run_<unixnano> or run_<ulid>)"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the export completed (RFC 3339)"
    },
    "exported_by": {
      "type": "string",
      "description": "Tool and version that performed the export (e.g., gonimbus/0.1.8)"
    },
    "artifacts": {
      "type": "object",
      "description": "Checksums and sizes of exported artifacts for integrity verification",
      "required": [
        "index_db"
      ],
      "additionalProperties": false,
      "properties": {
        "index_db": {
          "$ref": "#/$defs/artifact_entry"
        },
        "identity_json": {
          "$ref": "#/$defs/artifact_entry"
        }
      }
    },
    "source": {
      "type": "object",
      "description": "Provenance of the exported index run",
      "additionalProperties": false,
      "properties": {
        "base_uri": {
          "type": "string",
          "description": "The base URI this index covers"
        },
        "provider": {
          "type": "string",
          "description": "Storage provider (e.g., s3)"
        },
        "run_status": {
          "type": "string",
          "enum": [
            "success",
            "partial",
            "failed"
          ],
          "description": "Status of the source run at export time"
        },
        "run_started_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the source run started"
        },
        "run_ended_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the source run ended"
        },
        "object_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of objects in the index at export time"
        },
        "total_size_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Total size of indexed objects in bytes"
        }
      }
    },
    "provider_meta": {
      "type": "object",
      "description": "Provider-opaque hints (e.g., GCS generation). Values are strings; keys are provider-specific.",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "artifact_entry": {
      "type": "object",
      "description": "Checksum and size of a single exported artifact",
      "required": [
        "size_bytes",
        "sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Artifact size in bytes"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "SHA-256 hex digest of the artifact content"
        },
        "etag": {
          "type": "string",
          "description": "Provider ETag returned after upload (for cache validation)"
        }
      }
    }
  }
}
